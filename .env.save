cd ~/youtube_ato
python3 run.py deep-sleep
OPENAI_API_KEY=sk-...
REPLICATE_API_KEY=r8_...

# YouTube OAuth2 — download client_secret.json from Google Console
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json

# Channel IDs (optional — for logging)
WORK_CHANNEL_ID=UCxxxxxxxxxxxxxxxx
SLEEP_CHANNEL_ID=UCxxxxxxxxxxxxxxxx
